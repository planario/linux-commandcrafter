# ─── Linux CommandCrafter — environment variables ───────────────────────────
#
# Copy this file to `.env` and fill in your values.
# Loaded at startup by python-dotenv. NEVER commit the real `.env`.
# All values below are RUNTIME — restarting the app picks them up,
# no rebuild needed.
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini API key — required for the Command Analyzer feature.
# Leave empty to disable the analyzer (the rest of the app still works).
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Bind address and port for the dev server / gunicorn.
HOST=0.0.0.0
PORT=7256

# Set to "true" only in development. Never enable in production.
DEBUG=false

# Optional: override the Gemini model name.
GEMINI_MODEL=gemini-2.0-flash

# Optional: seconds between accepted /api/analyze requests per IP.
ANALYZE_COOLDOWN_SECONDS=10
